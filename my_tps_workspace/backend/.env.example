# Backend Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3001
NODE_ENV=development

# Database (SQLite)
DB_PATH=./data/tps.db

# File Storage
UPLOAD_DIR=./uploads

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
HMAC_SECRET=your-hmac-secret-for-file-downloads-change-in-production

# CORS
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info

# AI Contouring Service (Phase 4)
AI_CONTOURING_ENDPOINT=http://localhost:8080/segment
